#!/usr/bin/env bash
# cm - CMake project helper
#
# Creates or updates a CMake build directory from the current project root.
# Run from the project root (where CMakeLists.txt lives) or from inside an
# existing build directory (detected by the presence of CMakeCache.txt).
#
# Usage: cm [-r] [-o] [-h] [CMAKE_ARGS...]
#   -r           reset (wipe) the build directory before configuring
#   -o           open the project file after configuring (Xcode/Makefile)
#   CMAKE_ARGS   extra arguments forwarded to cmake
#   -h           show this help

usage() {
    echo "Usage: $(basename $0) [-r] [-o] [-h] [CMAKE_ARGS...]"
    echo "  -r   reset build directory"
    echo "  -o   open project file after configure"
    echo "  -h   show this help"
}

BUILD_DIR=build
WD=$(pwd)
CMARGS="$@"
POST=

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage; exit 0
fi

# check where we are is valid
if [ -f ./CMakeCache.txt ]; then
	BUILD_DIR=$(basename `pwd`)
	cd ..
else
    if [ ! -f ./CMakeLists.txt ]; then
        echo "No CMakeLists.txt. Are you in a cmake project?"
        exit 1
    fi
	[ -d $BUILD_DIR ] || (mkdir $BUILD_DIR)
fi

echo "Build dir: $BUILD_DIR"

if [ "$1" = "-r" ]; then
	echo "Reseting build dir..."
	rm -r $BUILD_DIR/*
	shift
	CMARGS="$@"
fi

if [ "$1" = "-o" ]; then
	POST=open_project
	shift
	CMARGS="$@"
fi

function open_project {
	if [ -f Makefile ]; then
		open Makefile
	elif [ -d *.xcodeproj ]; then
		open "$(ls -d *.xcodeproj)"
	fi
}

cd $BUILD_DIR
pwd
cmake "$CMARGS" ..
$POST
cd $WD
