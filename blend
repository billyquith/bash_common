#!/usr/bin/env bash
# blend - launch Blender using bookmarked directories
#
# Reads DIR_blender and DIR_blconfig from ~/.sdirs (set via bookmark `bs`).
# Optionally adds DIR_gameplay tools to PATH before launching.
# All arguments are passed through to the Blender executable.
#
# Usage: blend [BLENDER_ARGS...]
#   -h   show this help
#
# Required bookmarks:
#   DIR_blender   path to Blender.app/Contents
#   DIR_blconfig  path to Blender config dir (~/Library/Application Support/Blender/X.YY)

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,13p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

source $HOME/.sdirs

BLEND="$DIR_blender"
CONFIG="$DIR_blconfig"

if [ -z "$BLEND" ]; then
    echo 'Please set DIR_blender using bookmarks'
    exit 1
fi

if [ ! -d "$BLEND/MacOS" ]; then
    echo 'DIR_blender needs to point to Contents of Blender app'
    exit 1
fi

if [ -z "$CONFIG" ]; then
    echo 'Please set DIR_blconfig using bookmarks: ~/Library/Application Support/Blender/X.YY'
    exit 1
fi

if [ ! -d "$CONFIG/config" ]; then
    echo 'DIR_blconfig needs to point to Blender config dir'
    exit 1
fi

# Put Gameplay tools in the path
if [ ! -z "$DIR_gameplay" ]; then
    export PATH="$PATH:$DIR_gameplay/bin/macosx"
fi

EXE="$BLEND/MacOS/blender"
exec "$EXE" "$@"
