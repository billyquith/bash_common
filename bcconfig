#!/usr/bin/env python3
"""
bcconfig - Show or create .bcconfig settings for the current directory.

.bcconfig files are INI-format files that can live in any directory from ~
down to your current directory (like .gitignore). Settings in closer-to-pwd
files override those in parent directories. Each setting shows which file it
came from; values overridden by a child file are annotated.

Usage:
    bcconfig                              show all effective settings
    bcconfig COMMAND                      filter to [COMMAND] and [COMMAND.*] sections
    bcconfig --files                      list source files in load order
    bcconfig --get SECTION.KEY            print a single effective value
    bcconfig --get SECTION.KEY --fallback VALUE   print value or fallback
    bcconfig --init [COMMAND]             create a .bcconfig in the cwd with
                                          commented defaults for all (or COMMAND)
                                          sections; uses current effective values
"""

import argparse
import configparser
import importlib.machinery
import importlib.util
import os
import sys

_CONFIG_NAME = ".bcconfig"


def _find_bcconfig_files(cwd=None):
    """Return list of .bcconfig file paths in load order (lowest priority first).

    For cwd under home: scans from ~ down to cwd.
    For cwd outside home (e.g. an external volume): scans from ~ plus from
    the filesystem root down to cwd, so local configs on external volumes are
    still found and take precedence over ~/.bcconfig.
    """
    home = os.path.expanduser("~")
    cwd  = os.path.abspath(cwd or os.getcwd())

    paths = []
    home_cfg = os.path.join(home, _CONFIG_NAME)
    if os.path.isfile(home_cfg):
        paths.append(home_cfg)

    try:
        rel = os.path.relpath(cwd, home)
    except ValueError:
        rel = ".."  # different drive on Windows — treat as outside home

    if rel.startswith(".."):
        # cwd is outside home: walk upward from cwd to filesystem root
        # collecting configs, then reverse so root → cwd order (cwd wins).
        outside = []
        current = cwd
        while True:
            candidate = os.path.join(current, _CONFIG_NAME)
            if os.path.isfile(candidate):
                outside.append(candidate)
            parent = os.path.dirname(current)
            if parent == current:   # reached filesystem root
                break
            current = parent
        outside.reverse()
        paths.extend(outside)
        return paths

    # cwd is under home: walk subdirectory by subdirectory from home to cwd.
    parts = [p for p in rel.split(os.sep) if p and p != "."]
    current = home
    for part in parts:
        current = os.path.join(current, part)
        candidate = os.path.join(current, _CONFIG_NAME)
        if os.path.isfile(candidate):
            paths.append(candidate)

    return paths


def _load_with_provenance(files):
    """Load and merge .bcconfig files, tracking per-key provenance.

    Returns:
        merged:    RawConfigParser with all keys merged (later files win)
        prov:      dict mapping (section, key) -> filepath of last writer
        overridden: set of (section, key) pairs overridden by a later file
    """
    prov = {}           # (section, key) -> filepath
    overridden = set()  # (section, key) pairs that were overridden

    merged = configparser.RawConfigParser()

    for filepath in files:
        single = configparser.RawConfigParser()
        single.read(filepath, encoding="utf-8")
        for section in single.sections():
            if not merged.has_section(section):
                merged.add_section(section)
            for key, value in single.items(section):
                if (section, key) in prov:
                    overridden.add((section, key))
                merged.set(section, key, value)
                prov[(section, key)] = filepath

    return merged, prov, overridden


def _abbrev(path):
    """Replace home directory prefix with ~."""
    home = os.path.expanduser("~")
    if path == home or path.startswith(home + os.sep):
        return "~" + path[len(home):]
    return path


def _show(args):
    files = _find_bcconfig_files()
    if not files:
        print("No .bcconfig files found between ~ and cwd.")
        return

    merged, prov, overridden = _load_with_provenance(files)

    print("Sources (base → leaf):")
    for f in files:
        print(f"  {_abbrev(f)}")

    cmd = args.command.lower() if args.command else None
    sections = [
        s for s in merged.sections()
        if not cmd or s.lower() == cmd or s.lower().startswith(cmd + ".")
    ]

    if not sections:
        msg = f"No sections matching '{cmd}'." if cmd else "Config is empty."
        print(f"\n{msg}")
        return

    # Column widths for alignment
    all_keys = [k for s in sections for k in merged.options(s)]
    all_vals = [merged.get(s, k) for s in sections for k in merged.options(s)]
    max_key = max((len(k) for k in all_keys), default=0)
    max_val = max((len(v) for v in all_vals), default=0)

    for section in sections:
        print(f"\n[{section}]")
        for key in merged.options(section):
            value = merged.get(section, key)
            source = _abbrev(prov.get((section, key), "?"))
            annot = "  ← overridden" if (section, key) in overridden else ""
            print(f"  {key:<{max_key}} = {value:<{max_val}}  {source}{annot}")


def _files(args):
    for f in _find_bcconfig_files():
        print(_abbrev(f))


def _get(args):
    # Split on last dot: everything before = section, last component = key
    dot = args.key.rfind(".")
    if dot < 1:
        sys.exit(
            f"Error: --get expects SECTION.KEY (e.g. video.convert.crf), "
            f"got: {args.key!r}"
        )
    section, key = args.key[:dot], args.key[dot + 1:]

    files = _find_bcconfig_files()
    merged, _, _ = _load_with_provenance(files)

    try:
        print(merged.get(section, key))
    except (configparser.NoSectionError, configparser.NoOptionError):
        if args.fallback is not None:
            print(args.fallback)
        else:
            sys.exit(
                f"Error: {section}.{key} not found "
                f"(use --fallback to supply a default)"
            )


# ---------------------------------------------------------------------------
# Schema: bcconfig's own settings.
# Schemas for other commands live in their own script files as BCCONFIG_SCHEMA.
# Each entry: (key, default, description)
# ---------------------------------------------------------------------------

_OWN_SCHEMA = {
    "bash_common": [
        ("editor", "mate", "Default text/source editor (e.g. mate, code, vi)"),
    ],
}

_BC_DIR = os.path.dirname(os.path.abspath(__file__))


def _load_command_schema(name):
    """Import a command script by name from the BC_INSTALL_DIR and return its
    BCCONFIG_SCHEMA dict, or {} if it doesn't define one.

    Uses SourceFileLoader directly because the scripts have no .py extension.
    """
    path = os.path.join(_BC_DIR, name)
    if not os.path.isfile(path):
        return {}
    try:
        loader = importlib.machinery.SourceFileLoader(name, path)
        spec   = importlib.util.spec_from_loader(name, loader)
        mod    = importlib.util.module_from_spec(spec)
        loader.exec_module(mod)
        return getattr(mod, "BCCONFIG_SCHEMA", {})
    except Exception:
        return {}


def _has_schema(name):
    """Return True if the file contains the BCCONFIG_SCHEMA marker without
    loading it. Avoids exec'ing scripts that do argument parsing at module level."""
    path = os.path.join(_BC_DIR, name)
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as fh:
            return "BCCONFIG_SCHEMA" in fh.read()
    except OSError:
        return False


def _all_schemas():
    """Return a merged schema dict from all command scripts that expose
    BCCONFIG_SCHEMA, plus bcconfig's own _OWN_SCHEMA."""
    merged = dict(_OWN_SCHEMA)
    for fname in sorted(os.listdir(_BC_DIR)):
        fpath = os.path.join(_BC_DIR, fname)
        if not os.path.isfile(fpath) or fname.startswith(".") or fname == "bcconfig":
            continue
        if not _has_schema(fname):
            continue
        schema = _load_command_schema(fname)
        merged.update(schema)
    return merged


def _init(args):
    """Create a .bcconfig template in the current working directory."""
    dest = os.path.join(os.getcwd(), _CONFIG_NAME)

    if os.path.exists(dest):
        print(f"Error: {_abbrev(dest)} already exists. Remove it first or edit it directly.")
        sys.exit(1)

    # Load schema: try the named command's file first, fall back to full scan
    cmd = args.command.lower() if args.command else None
    if cmd:
        # Try loading just the named command's schema first (fast path)
        cmd_schema = _load_command_schema(cmd) if _has_schema(cmd) else {}
        if cmd_schema:
            full_schema = dict(_OWN_SCHEMA)
            full_schema.update(cmd_schema)
        else:
            full_schema = _all_schemas()
    else:
        full_schema = _all_schemas()

    sections = {
        s: keys for s, keys in full_schema.items()
        if not cmd or s.lower() == cmd or s.lower().startswith(cmd + ".")
    }

    if not sections:
        print(f"Error: no known sections match '{cmd}'.")
        print(f"Known sections: {', '.join(full_schema)}")
        sys.exit(1)

    # Load current effective values so the template reflects real defaults
    files = _find_bcconfig_files()
    merged, _, _ = _load_with_provenance(files)

    lines = [
        f"# .bcconfig — local configuration override",
        f"# Created in: {_abbrev(os.getcwd())}",
        f"#",
        f"# All keys are commented out. Uncomment and edit only the ones you",
        f"# want to override. Unset keys fall back to parent .bcconfig files.",
        f"# Run 'bcconfig' to see the full effective settings for this directory.",
        f"",
    ]

    for section, keys in sections.items():
        lines.append(f"[{section}]")
        max_key_len = max(len(k) for k, _, _ in keys)
        for key, default, desc in keys:
            # Use current effective value if available, otherwise hardcoded default
            try:
                effective = merged.get(section, key)
            except Exception:
                effective = default
            lines.append(f"# {desc}")
            lines.append(f"# {key:<{max_key_len}} = {effective}")
        lines.append("")

    content = "\n".join(lines)
    with open(dest, "w", encoding="utf-8") as fh:
        fh.write(content)

    print(f"Created: {_abbrev(dest)}")
    if cmd:
        print(f"Sections: {', '.join(f'[{s}]' for s in sections)}")
    else:
        print(f"Sections: {', '.join(f'[{s}]' for s in sections)}")
    print(f"Uncomment keys you want to override, then run 'bcconfig' to verify.")


def main():
    p = argparse.ArgumentParser(
        prog="bcconfig",
        description="Show effective .bcconfig settings for the current directory.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  bcconfig                              show all effective settings
  bcconfig video                        show [video] and [video.*] sections only
  bcconfig --files                      list source .bcconfig files in load order
  bcconfig --get video.convert.crf      print a single effective value
  bcconfig --get video.convert.crf --fallback 23
  bcconfig --init                       create .bcconfig in cwd with all sections
  bcconfig --init video.normalise       create .bcconfig with only [video.normalise]
""",
    )
    p.add_argument(
        "command", nargs="?", metavar="COMMAND",
        help="filter output to [COMMAND] and [COMMAND.*] sections",
    )
    p.add_argument(
        "--files", action="store_true",
        help="list source .bcconfig files in load order",
    )
    p.add_argument(
        "--get", metavar="SECTION.KEY",
        help="print the effective value of SECTION.KEY",
    )
    p.add_argument(
        "--fallback", metavar="VALUE",
        help="value to use when --get key is not found",
    )
    p.add_argument(
        "--init", action="store_true",
        help="create a .bcconfig template in the cwd with commented defaults; "
             "combine with COMMAND to include only matching sections "
             "(e.g. bcconfig --init video.normalise)",
    )

    args = p.parse_args()

    if args.init:
        _init(args)
    elif args.files:
        _files(args)
    elif args.get:
        args.key = args.get
        _get(args)
    else:
        _show(args)


if __name__ == "__main__":
    main()
