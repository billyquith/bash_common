#!/usr/bin/env bash
# newsh - create a new Bash script from a starter template
#
# Creates an executable Bash script at the given path, pre-filled with a
# standard bash_common template including a usage() function and getopts
# skeleton. The file is made executable automatically.
#
# Usage: newsh FILENAME [-h]
#   FILENAME   path/name for the new script
#   -h         show this help

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,10p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

FNAME="$1"

if [ -z "$FNAME" ]; then
    echo "Error: no filename given"
    echo "Usage: $(basename $0) FILENAME"
    exit 1
fi

if [ -e "$FNAME" ]; then
    echo "Script already exists"
    exit 1
fi

cat << 'EOF' >> "$FNAME"
#!/usr/bin/env bash

SCRIPTPATH=$( cd $(dirname $0) ; pwd -P )

FILE=$1
OUT=${FILE%.*}_.mp4

usage() {
  echo "Usage: $0 [-i] [-c] VIDEO"
}

# getopt "x" no-arg, "x:" required arg, "x::" optional arg
while getopts "ic" OPT; do
  case "${OPT}" in
    i)
      echo "$FILE"
      shift
      ;;
    c)
      blah
      shift
      ;;
    *) usage ;;
  esac
done

shift "$((OPTIND-1))"

ARGS=$@

EOF

chmod u+x "$FNAME"
