#!/usr/bin/env python3
"""bcdoctor - diagnostics for bash_common metadata-backed commands."""

import argparse
import json
import os
import sys

from lib.bc_metadata import inspect_commands


def main():
    parser = argparse.ArgumentParser(
        prog="bcdoctor",
        description="Validate bash_common command metadata discovery.",
    )
    parser.add_argument("--json", action="store_true", help="print machine-readable diagnostics")
    parser.add_argument("--timeout", type=float, default=3, help="metadata command timeout in seconds")
    args = parser.parse_args()

    bc_dir = os.environ.get("BC_INSTALL_DIR") or os.path.dirname(os.path.abspath(__file__))
    report = inspect_commands(bc_dir, timeout=args.timeout)

    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"Discovered {len(report['commands'])} metadata-backed commands.")
        for command in report["commands"]:
            print(f"  [ok] {command['name']} ({command.get('_path')})")
        if report["diagnostics"]:
            print("")
            print("Metadata issues:")
            for item in report["diagnostics"]:
                detail = item.get("message") or item.get("stderr") or ""
                print(f"  [{item['status']}] {item['path']} {detail}".rstrip())

    return 1 if report["diagnostics"] else 0


if __name__ == "__main__":
    sys.exit(main())
