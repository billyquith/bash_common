#!/usr/bin/env bash
# video-tomp4 - show media info or convert video to H.264 MP4 (DEPRECATED)
#
# DEPRECATED: use the `video` command instead:
#   video info FILE
#   video convert [-f FORMAT] [-o OUTPUT] FILE
# This script is kept for backwards compatibility only.
#
# Usage: video-tomp4 [-i] [-c] [-h] FILE
#   -i   show media info
#   -c   convert to H.264 MP4
#   -h   show this help

usage() {
  echo "Usage: $(basename $0) [-i] [-c] [-h] FILE"
  echo "  -i   show media info (via mediainfo)"
  echo "  -c   convert to H.264 MP4"
  echo "  -h   show this help"
  echo "NOTE: deprecated — use 'video info FILE' or 'video convert FILE' instead."
}

while getopts "ich" OPT; do
  case "${OPT}" in
    i)
      FILE="${@:$OPTIND:1}"
      mediainfo "$FILE"
      ;;
    c)
      FILE="${@:$OPTIND:1}"
      OUT="${FILE%.*}_.mp4"
      ffmpeg -i "$FILE" -vcodec libx264 -acodec aac "$OUT"
      ;;
    h) usage; exit 0 ;;
    *) usage; exit 1 ;;
  esac
done



