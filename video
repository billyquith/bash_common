  <div class="stat"><span class="val">{len(entries)}</span><span class="lbl">Files</span></div>
  <div class="stat"><span class="val">{_fmt_size(total_size)}</span><span class="lbl">Total size</span></div>
  <div class="stat"><span class="val">{_fmt_duration(total_duration)}</span><span class="lbl">Total duration</span></div>
  {"" if not errors else f'<div class="stat warn"><span class="val">{errors}</span><span class="lbl">Probe errors</span></div>'}
