def cmd_normalise(args):
    _require("ffmpeg", "ffprobe")

    directory = args.directory
    if not os.path.isdir(directory):
        sys.exit(f"Error: not a directory: {directory}")

    cfg = _load_config(directory)
    def gcfg(section, key, fallback):
        return _vcfg(section, key, fallback, cfg=cfg)

    target_w    = int(gcfg("normalise", "target_width",   "1280"))
    target_h    = int(gcfg("normalise", "target_height",  "720"))
    target_fmt  = gcfg("normalise", "format",         "mp4")
    vcodec      = gcfg("normalise", "video_codec",    "libx264")
    acodec      = gcfg("normalise", "audio_codec",    "aac")
    preset      = gcfg("normalise", "video_preset",   "medium")
    crf         = gcfg("normalise", "video_crf",      "23")
    abitrate    = gcfg("normalise", "audio_bitrate",  "128k")
    deinterlace = gcfg("normalise", "deinterlace",    "auto").lower()
    orig_dir    = os.path.expanduser(gcfg("normalise", "original_dir", "/tmp/video-originals"))
    report_path = args.output or os.path.join(directory, "normalise-report.html")

    want_vc = _VCODEC_PROBE.get(vcodec, vcodec)
    want_ac = _ACODEC_PROBE.get(acodec, acodec)
    target_str = f"{vcodec} {target_w}×{target_h} / {acodec} .{target_fmt}"

    # Collect tool versions and config metadata for the report
    ffmpeg_ver  = _tool_version("ffmpeg")
    ffprobe_ver = _tool_version("ffprobe")
    python_ver  = f"Python {sys.version.split()[0]}"
    cfg_paths   = [os.path.join(BCCFG, "video.ini")]
    local_ini   = os.path.join(os.path.abspath(directory), "video.ini")
    if os.path.isfile(local_ini):
        cfg_paths.append(local_ini)

    print(f"Normalizing : {os.path.abspath(directory)}")
    print(f"Target      : {target_str}")
    print(f"Originals   → {orig_dir}")
    print(f"Tools       : {ffmpeg_ver}  |  {ffprobe_ver}")
    if args.dry_run:
        print("(dry run — no files will be changed)")
    print()

    results = []
    run_start = time.monotonic()

    for root, dirs, files in os.walk(directory):
        dirs.sort()
        for fname in sorted(files):
            if os.path.splitext(fname)[1].lower() not in VIDEO_EXTENSIONS:
                continue

            full_path = os.path.join(root, fname)
            rel_path  = os.path.relpath(full_path, directory)

            before = _norm_probe(full_path)
            if not before["video_codec"]:
                print(f"  [error]   {rel_path}: probe failed or no video stream")
                results.append({"path": rel_path, "status": "error",
                                 "before": before, "after": None, "elapsed": None,
                                 "reasons": [], "error_msg": "probe failed"})
                continue

            needs_deint  = deinterlace == "yes" or (deinterlace == "auto" and before["interlaced"])
            needs_scale  = (before["width"] != target_w or before["height"] != target_h)
            needs_vcodec = (before["video_codec"] != want_vc)
            needs_acodec = (before["audio_codec"] != want_ac)
            needs_fmt    = (target_fmt not in before["format"])
            already_ok   = not any([needs_vcodec, needs_acodec, needs_scale, needs_fmt, needs_deint])

            if already_ok and not args.force:
                print(f"  [ok]      {rel_path}")
                results.append({"path": rel_path, "status": "skipped",
                                 "before": before, "after": before,
                                 "reasons": [], "elapsed": None})
                continue

            reasons = []
            if needs_vcodec: reasons.append(f"vcodec {before['video_codec']}→{want_vc}")
            if needs_acodec: reasons.append(f"acodec {before['audio_codec']}→{want_ac}")
            if needs_scale:  reasons.append(f"res {before['width']}×{before['height']}→{target_w}×{target_h}")
            if needs_fmt:    reasons.append(f"format {before['format']}→{target_fmt}")
            if needs_deint:  reasons.append("deinterlace")
            if args.force and already_ok: reasons.append("forced")

            print(f"  [convert] {rel_path}  ({', '.join(reasons)})")

            if args.dry_run:
                results.append({"path": rel_path, "status": "converted",
                                 "before": before, "after": None,
                                 "reasons": reasons, "elapsed": None})
                continue

            backup_path = os.path.join(orig_dir, rel_path)
            os.makedirs(os.path.dirname(os.path.abspath(backup_path)), exist_ok=True)
            out_name = os.path.splitext(fname)[0] + f".{target_fmt}"
            out_path = os.path.join(root, out_name)

            try:
                shutil.move(full_path, backup_path)

                vf_parts = []
                if needs_deint:
                    vf_parts.append("yadif=mode=0")
                if needs_scale or needs_deint:
                    vf_parts.append(_scale_filter(target_w, target_h))

                cmd = ["ffmpeg", "-i", backup_path]
                if vf_parts:
                    cmd += ["-vf", ",".join(vf_parts)]
                cmd += ["-vcodec", vcodec, "-crf", crf, "-preset", preset,
                        "-acodec", acodec, "-b:a", abitrate, out_path]

                t0 = time.monotonic()
                _run(cmd)
                elapsed = time.monotonic() - t0

                after = _norm_probe(out_path)
                print(f"             → {_fmt_elapsed(elapsed)}", end="")
                if before["duration"] and elapsed > 0:
                    print(f"  ({before['duration'] / elapsed:.1f}× realtime)", end="")
                print()
                results.append({"path": rel_path, "status": "converted",
                                 "before": before, "after": after,
                                 "reasons": reasons, "elapsed": elapsed})

            except Exception as exc:
                msg = str(exc)
                print(f"  [error]   {rel_path}: {msg}")
                if os.path.isfile(backup_path) and not os.path.isfile(full_path):
                    shutil.move(backup_path, full_path)
                    print(f"            original restored")
                results.append({"path": rel_path, "status": "error",
                                 "before": before, "after": None,
                                 "reasons": reasons, "elapsed": None, "error_msg": msg})

    total_elapsed = time.monotonic() - run_start
    conv    = sum(1 for r in results if r["status"] == "converted")
    skipped = sum(1 for r in results if r["status"] == "skipped")
    errors  = sum(1 for r in results if r["status"] == "error")

    print()
    print(f"Done: {conv} converted, {skipped} skipped, {errors} errors  ({_fmt_elapsed(total_elapsed)})")

    run_info = {
        "target_fmt":     target_fmt,
        "vcodec":         vcodec,
        "acodec":         acodec,
        "crf":            crf,
        "preset":         preset,
        "abitrate":       abitrate,
        "target_res":     f"{target_w}×{target_h}",
        "deinterlace":    deinterlace,
        "orig_dir":       orig_dir,
        "ffmpeg_ver":     ffmpeg_ver,
        "ffprobe_ver":    ffprobe_ver,
        "python_ver":     python_ver,
        "total_elapsed":  _fmt_elapsed(total_elapsed),
        "config_files":   cfg_paths,
    }

    html = _normalise_html(directory, results, target_str, orig_dir, args.dry_run, run_info)
    with open(report_path, "w", encoding="utf-8") as fh:
        fh.write(html)
    print(f"Report: {report_path}")

    if errors:
        sys.exit(1)


