def _norm_check_cell(check):
    """Render one criterion cell for the assessment report."""
    cls = "ok" if check["ok"] else "bad"
    cur = check["current"]
    if check["ok"]:
        return f'<td class="{cls}">{cur}</td>'
    tgt = check["target"]
    return (
        f'<td class="{cls}" title="{check["fix"]}">'
        f'{cur}<br><span class="fix">→ {tgt}</span></td>'
    )


