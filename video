# ffprobe codec names differ from the ffmpeg encoder names
_VCODEC_PROBE = {"libx264": "h264", "libx265": "hevc", "libvpx-vp9": "vp9"}
_ACODEC_PROBE = {"libmp3lame": "mp3", "libopus": "opus"}


def _is_interlaced(stream):
    field_order = stream.get("field_order", "progressive")
    return field_order not in ("progressive", "unknown", "")


def _scale_filter(target_h):
    """Return an ffmpeg vf scale expression that scales to target_h, with the
    width auto-calculated from the source aspect ratio using lanczos resampling.
    -2 ensures the auto-calculated width is divisible by 2 (required by most
    codecs). Aspect ratio is always preserved — no padding or cropping."""
    return f"scale=-2:{target_h}:flags=lanczos"


def _tool_version(tool):
    """Return the version string for *tool* (e.g. 'ffmpeg 6.1.1'), or 'unknown'."""
    try:
        out = subprocess.check_output(
            [tool, "-version"], stderr=subprocess.STDOUT
        ).decode(errors="replace")
        first = out.splitlines()[0]          # e.g. "ffmpeg version 6.1.1 Copyright ..."
        # grab everything up to the first "Copyright" / "built" clause
        return first.split("Copyright")[0].split(" built")[0].strip()
    except Exception:
        return f"{tool} (unknown version)"


def _fmt_elapsed(secs):
    """Format elapsed seconds as 'Xm Ys' or 'Xs'."""
    secs = int(secs)
    m, s = divmod(secs, 60)
    return f"{m}m {s:02d}s" if m else f"{s}s"


def _norm_assess(before, deinterlace, target_h, want_vc, want_ac, target_fmt):
    """Compare *before* probe data against normalise targets.

    Returns a dict with compliant (bool), reasons (list[str]), and checks
    (list of per-criterion dicts for HTML rendering).

    Resolution is checked by height only — width is derived from the source
    aspect ratio so files at the correct height are never needlessly rescaled.
    """
    needs_deint  = deinterlace == "yes" or (deinterlace == "auto" and before["interlaced"])
    needs_scale  = (before["height"] > target_h)   # clamp only — never upscale
    needs_vcodec = (before["video_codec"] != want_vc)
    needs_acodec = (before["audio_codec"] != want_ac)
    # Use the full comma-separated format_names string for detection so that a
    # file reported as "mov,mp4,m4a,…" by ffprobe is not falsely flagged as
    # needing conversion when the target is already "mp4".
    needs_fmt    = (target_fmt not in before.get("format_names", before["format"]))

    res_current = f'{before["width"]}×{before["height"]}' if before["width"] else "—"
    res_target  = f"h={target_h}"

    checks = [
        {
            "label": "Video codec",
            "ok": not needs_vcodec,
            "current": before["video_codec"] or "—",
            "target": want_vc,
            "fix": f"re-encode video: {before['video_codec']} → {want_vc}",
        },
        {
            "label": "Audio codec",
            "ok": not needs_acodec,
            "current": before["audio_codec"] or "—",
            "target": want_ac,
            "fix": f"re-encode audio: {before['audio_codec'] or 'none'} → {want_ac}",
        },
        {
            "label": "Resolution",
            "ok": not needs_scale,
            "current": res_current,
            "target": res_target,
            "fix": f"scale down to h={target_h} (width auto from aspect): {res_current}",
        },
        {
            "label": "Container",
            "ok": not needs_fmt,
            "current": before["format"] or "—",
            "target": target_fmt,
            "fix": f"remux/transcode: {before['format']} → {target_fmt}",
        },
        {
            "label": "Deinterlace",
            "ok": not needs_deint,
            "current": "interlaced" if before["interlaced"] else "progressive",
            "target": "progressive",
            "fix": "deinterlace (yadif)",
        },
    ]

    reasons = []
    if needs_vcodec:
        reasons.append(f"vcodec {before['video_codec']}→{want_vc}")
    if needs_acodec:
        reasons.append(f"acodec {before['audio_codec'] or 'none'}→{want_ac}")
    if needs_scale:
        reasons.append(f"scale down {res_current}→{res_target}")
    if needs_fmt:
        reasons.append(f"format {before['format']}→{target_fmt}")
    if needs_deint:
        reasons.append("deinterlace")

    compliant = not any([needs_vcodec, needs_acodec, needs_scale, needs_fmt, needs_deint])
    return {"compliant": compliant, "reasons": reasons, "checks": checks}


def _norm_probe(path):
    """Probe *path* and return a compact summary dict for the normalise report."""
    e = {
        "size": 0, "format": "", "format_names": "", "duration": 0.0, "bitrate": 0,
        "video_codec": "", "width": 0, "height": 0, "fps": "",
        "audio_codec": "", "channels": "", "interlaced": False,
    }
    try:
        e["size"] = os.path.getsize(path)
        data = _probe(path)
        fmt = data.get("format", {})
        raw_fmt = fmt.get("format_name", "")
        e["format"]       = raw_fmt.split(",")[0]   # first name for display
        e["format_names"] = raw_fmt                 # all names for detection
        e["duration"] = float(fmt.get("duration") or 0)
        e["bitrate"]  = int(fmt.get("bit_rate")   or 0)
        for s in data.get("streams", []):
            ctype = s.get("codec_type")
            if ctype == "video" and not e["video_codec"]:
                e["video_codec"] = s.get("codec_name", "")
                e["width"]       = int(s.get("width",  0))
                e["height"]      = int(s.get("height", 0))
                e["fps"]         = _fmt_fps(s.get("avg_frame_rate", ""))
                e["interlaced"]  = _is_interlaced(s)
            elif ctype == "audio" and not e["audio_codec"]:
                e["audio_codec"] = s.get("codec_name", "")
                e["channels"]    = s.get("channels", "")
    except Exception:
        pass
    return e


def _run_info_section(run_info):
    """Render the collapsible Run Information section, or empty string if no info."""
    if not run_info:
        return ""

    def row(k, v):
        return f'<tr><td>{k}</td><td>{v}</td></tr>'

    cfg_rows = "".join([
        row("Target format",   run_info.get("target_fmt", "—")),
        row("Video codec",     run_info.get("vcodec", "—")),
        row("Audio codec",     run_info.get("acodec", "—")),
        row("CRF",             run_info.get("crf", "—")),
        row("Preset",          run_info.get("preset", "—")),
        row("Audio bitrate",   run_info.get("abitrate", "—")),
        row("Target resolution", run_info.get("target_res", "—")),
