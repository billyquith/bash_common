# CLI
# ---------------------------------------------------------------------------

def build_parser():
    parser = argparse.ArgumentParser(
        prog="video",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", metavar="SUBCOMMAND")
    sub.required = True

    # formats
    p = sub.add_parser("formats",
                       help="explain supported formats and codecs, check ffmpeg availability")
    p.add_argument("--all", action="store_true",
                   help="also list every encoder available in the installed ffmpeg")

    # info
    p = sub.add_parser("info", help="print detailed file, container and stream information")
    p.add_argument("file", metavar="FILE")
    p.add_argument("--json", action="store_true",
                   help="dump raw ffprobe JSON instead of formatted output")

    # convert
    default_fmt = _vcfg("video", "default_format", "mp4")
    p = sub.add_parser("convert",
                       help="transcode a file using config defaults (all overridable via args)")
    p.add_argument("file", metavar="FILE")
    p.add_argument("-f", "--format", default=default_fmt, metavar="FORMAT",
                   help=f"container format: mp4, mkv, mov, webm (config: {default_fmt})")
    p.add_argument("-H", "--height", default=None, metavar="PX", type=int,
                   help="scale to this height in pixels, maintaining aspect ratio")
    p.add_argument("--vcodec", default=None, metavar="CODEC",
                   help=f"video codec (config: {_vcfg('video.convert','video_codec','libx264')})")
    p.add_argument("--acodec", default=None, metavar="CODEC",
                   help=f"audio codec (config: {_vcfg('video.convert','audio_codec','aac')})")
    p.add_argument("--crf", default=None, metavar="N", type=int,
                   help=f"CRF quality, lower=better (config: {_vcfg('video.convert','video_crf','20')})")
    p.add_argument("--preset", default=None, metavar="PRESET",
                   help=f"encoding preset (config: {_vcfg('video.convert','video_preset','slow')})")
    p.add_argument("--abitrate", default=None, metavar="RATE",
                   help=f"audio bitrate (config: {_vcfg('video.convert','audio_bitrate','160k')})")
    p.add_argument("-o", "--output", default=None, metavar="OUTPUT")

    # concat
    p = sub.add_parser("concat", help="join videos of the same format and resolution")
    p.add_argument("-o", "--output", default=None, metavar="OUTPUT",
                   help="output filename (default: output.mp4)")
    p.add_argument("files", nargs="+", metavar="FILE")

    # clamp
    p = sub.add_parser("clamp", help="cut to a time range (start and/or end optional)")
    p.add_argument("-s", "--start", default=None, metavar="TIME",
                   help="start time as HH:MM:SS or seconds (default: beginning of file)")
    p.add_argument("-e", "--end", default=None, metavar="TIME",
                   help="end time as HH:MM:SS or seconds (default: end of file)")
    p.add_argument("-o", "--output", default=None, metavar="OUTPUT")
    p.add_argument("file", metavar="FILE")

    # thumb
    p = sub.add_parser("thumb", help="extract a single frame as a PNG image")
    p.add_argument("-t", "--time", default=None, metavar="TIME",
                   help="timestamp to grab (default: 00:00:01)")
    p.add_argument("-H", "--height", default=None, metavar="PX", type=int,
                   help="scale to this height in pixels, maintaining aspect ratio")
    p.add_argument("-o", "--output", default=None, metavar="OUTPUT")
    p.add_argument("file", metavar="FILE")

    # catalog
    p = sub.add_parser("catalog",
                       help="scan a directory tree and write an HTML report")
    p.add_argument("directory", metavar="DIR",
                   help="root directory to scan recursively")
    p.add_argument("-o", "--output", default=None, metavar="OUTPUT",
                   help="output HTML file (default: catalog.html)")

    # normalise
    p = sub.add_parser("normalise",
                       help="batch-normalise a directory tree to a web-friendly format")
    p.add_argument("directory", metavar="DIR",
                   help="root directory to scan and normalise recursively")
    p.add_argument("-n", "--dry-run", action="store_true",
                   help="scan and assess without converting: writes a full HTML report "
                        "showing green/red compliance per criterion for every file")
    p.add_argument("-l", "--limit", type=int, default=None, metavar="N",
                   help="stop after converting N files; re-run to continue "
                        "(skipped/already-ok files do not count toward the limit)")
    p.add_argument("-f", "--force", action="store_true",
                   help="re-process files that already appear normalised")
    p.add_argument("-o", "--output", default=None, metavar="OUTPUT",
                   help="HTML report path (default: DIR/normalise-report.html)")

    return parser


def main():
    if len(sys.argv) == 2 and sys.argv[1] == "--bc-metadata":
        print(json.dumps(bc_metadata(), indent=2, sort_keys=True))
        return

    parser = build_parser()
    args = parser.parse_args()

    dispatch = {
        "catalog":   cmd_catalog,
        "formats":   cmd_formats,
        "concat":    cmd_concat,
        "convert":   cmd_convert,
        "info":      cmd_info,
        "normalise": cmd_normalise,
        "thumb":     cmd_thumb,
        "clamp":     cmd_clamp,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
