def cmd_normalise(args):
    _require("ffmpeg", "ffprobe")

    directory = args.directory
    if not os.path.isdir(directory):
        sys.exit(f"Error: not a directory: {directory}")

    cfg = _load_config(directory)
    def gcfg(section, key, fallback):
        return _vcfg(section, key, fallback, cfg=cfg)

    target_h    = int(gcfg("video.normalise", "target_height",  "720"))
    target_fmt  = gcfg("video.normalise", "format",         "mp4")
    vcodec      = gcfg("video.normalise", "video_codec",    "libx264")
    acodec      = gcfg("video.normalise", "audio_codec",    "aac")
    preset      = gcfg("video.normalise", "video_preset",   "slow")
    crf         = gcfg("video.normalise", "video_crf",      "20")
    abitrate    = gcfg("video.normalise", "audio_bitrate",  "160k")
    deinterlace = gcfg("video.normalise", "deinterlace",    "auto").lower()
    orig_dir    = os.path.expanduser(gcfg("video.normalise", "original_dir", "/tmp/video-originals"))
    report_path = args.output or os.path.join(directory, "normalise-report.html")

    want_vc = _VCODEC_PROBE.get(vcodec, vcodec)
    want_ac = _ACODEC_PROBE.get(acodec, acodec)
    target_str = f"{vcodec} h={target_h} (auto-width) / {acodec} .{target_fmt}"

    ffmpeg_ver  = _tool_version("ffmpeg")
    ffprobe_ver = _tool_version("ffprobe")
    python_ver  = f"Python {sys.version.split()[0]}"
    cfg_paths   = _find_bcconfig_files(directory)

    run_info = {
        "target_fmt":     target_fmt,
        "vcodec":         vcodec,
        "acodec":         acodec,
        "crf":            crf,
        "preset":         preset,
        "abitrate":       abitrate,
        "target_res":     f"h={target_h} (auto-width)",
        "deinterlace":    deinterlace,
        "orig_dir":       orig_dir,
        "ffmpeg_ver":     ffmpeg_ver,
        "ffprobe_ver":    ffprobe_ver,
        "python_ver":     python_ver,
        "config_files":   cfg_paths,
    }

    # ---- dry-run: assess every file and write the green/red HTML report ----
    if args.dry_run:
        print(f"Assessing  : {os.path.abspath(directory)}  (dry run — no files will be changed)")
        print(f"Target     : {target_str}")
        print()

        entries = []
        for root, dirs, files in os.walk(directory):
            dirs.sort()
            for fname in sorted(files):
                if os.path.splitext(fname)[1].lower() not in VIDEO_EXTENSIONS:
                    continue
                full_path = os.path.join(root, fname)
                rel_path  = os.path.relpath(full_path, directory)
                before = _norm_probe(full_path)
                if not before["video_codec"]:
                    print(f"  [error]   {rel_path}: probe failed or no video stream")
                    entries.append({"path": rel_path, "before": before,
                                      "error": "probe failed or no video stream"})
                    continue
                assess = _norm_assess(before, deinterlace, target_h,
                                      want_vc, want_ac, target_fmt)
                tag = "[ok]" if assess["compliant"] else "[change]"
                detail = "" if assess["compliant"] else f"  ({', '.join(assess['reasons'])})"
                print(f"  {tag:<9} {rel_path}{detail}")
                entries.append({"path": rel_path, "before": before, **assess})

        if not entries:
            sys.exit("No video files found.")

        ok_count  = sum(1 for e in entries if e.get("compliant"))
        bad_count = sum(1 for e in entries if not e.get("compliant") and not e.get("error"))
        err_count = sum(1 for e in entries if e.get("error"))

        html = _normalise_plan_html(directory, entries, target_str, run_info)
        with open(report_path, "w", encoding="utf-8") as fh:
            fh.write(html)

        print()
        print(f"Done: {ok_count} compliant, {bad_count} need changes"
              + (f", {err_count} errors" if err_count else ""))
        print(f"Report: {report_path}")
        if err_count:
            sys.exit(1)
        return

    limit = args.limit
    print(f"Normalizing : {os.path.abspath(directory)}")
    print(f"Target      : {target_str}")
    print(f"Originals   → {orig_dir}")
    print(f"Tools       : {ffmpeg_ver}  |  {ffprobe_ver}")
    if limit:
        print(f"Limit       : {limit} conversion(s)")
    print()

    results = []
    run_start = time.monotonic()
    n_converted = 0
    limit_reached = False

    for root, dirs, files in os.walk(directory):
        if limit_reached:
            break
        dirs.sort()
        for fname in sorted(files):
            if limit_reached:
                break
            if os.path.splitext(fname)[1].lower() not in VIDEO_EXTENSIONS:
                continue

            full_path = os.path.join(root, fname)
            rel_path  = os.path.relpath(full_path, directory)

            before = _norm_probe(full_path)
            if not before["video_codec"]:
                print(f"  [error]   {rel_path}: probe failed or no video stream")
                results.append({"path": rel_path, "status": "error",
                                 "before": before, "after": None, "elapsed": None,
                                 "reasons": [], "error_msg": "probe failed"})
                continue

            assess = _norm_assess(before, deinterlace, target_h,
                                  want_vc, want_ac, target_fmt)
            already_ok = assess["compliant"]

            if already_ok and not args.force:
                print(f"  [ok]      {rel_path}")
                results.append({"path": rel_path, "status": "skipped",
                                 "before": before, "after": before,
                                 "reasons": [], "elapsed": None})
                continue

            reasons = list(assess["reasons"])
            if args.force and already_ok:
                reasons.append("forced")

            remux_candidate = assess["compliant"] is False and len(assess["reasons"]) == 1 \
                              and assess["reasons"][0].startswith("format ")
            tag = "[remux]  " if remux_candidate else "[convert]"
            print(f"  {tag} {rel_path}  ({', '.join(reasons)})")

            backup_path = os.path.join(orig_dir, rel_path)
            os.makedirs(os.path.dirname(os.path.abspath(backup_path)), exist_ok=True)
            stem = _strip_emoji(os.path.splitext(fname)[0])
            out_name = stem + f".{target_fmt}"
            out_path = os.path.join(root, out_name)
            if stem != os.path.splitext(fname)[0]:
                print(f"  [rename]  {fname} → {out_name}")

            try:
                shutil.move(full_path, backup_path)

                needs_deint = any(c["label"] == "Deinterlace" and not c["ok"]
                                  for c in assess["checks"])
                needs_scale = any(c["label"] == "Resolution" and not c["ok"]
                                  for c in assess["checks"])
                needs_vcodec_enc = any(c["label"] == "Video codec" and not c["ok"]
                                       for c in assess["checks"])
                needs_acodec_enc = any(c["label"] == "Audio codec" and not c["ok"]
                                       for c in assess["checks"])

                # Stream copy (remux) when only the container format differs —
                # all streams are already the right codec and resolution.
                # This is lossless and takes seconds instead of minutes.
                remux_only = not any([needs_vcodec_enc, needs_acodec_enc,
                                      needs_scale, needs_deint])

                if remux_only:
                    cmd = ["ffmpeg", "-i", backup_path, "-c", "copy", out_path]
                else:
                    vf_parts = []
                    if needs_deint:
                        vf_parts.append("yadif=mode=0")
                    if needs_scale or needs_deint:
                        vf_parts.append(_scale_filter(target_h))
                    cmd = ["ffmpeg", "-i", backup_path]
                    if vf_parts:
                        cmd += ["-vf", ",".join(vf_parts)]
                    cmd += ["-vcodec", vcodec, "-crf", crf, "-preset", preset,
                            "-acodec", acodec, "-b:a", abitrate, out_path]

                t0 = time.monotonic()
                _run(cmd)
                elapsed = time.monotonic() - t0

                after = _norm_probe(out_path)
                print(f"             → {_fmt_elapsed(elapsed)}", end="")
                if before["duration"] and elapsed > 0:
                    print(f"  ({before['duration'] / elapsed:.1f}× realtime)", end="")
                print()
                results.append({"path": rel_path, "status": "converted",
                                 "before": before, "after": after,
                                 "reasons": reasons, "elapsed": elapsed})
                n_converted += 1
                if limit and n_converted >= limit:
                    limit_reached = True
                    break

            except Exception as exc:
                msg = str(exc)
                print(f"  [error]   {rel_path}: {msg}")
                if os.path.isfile(backup_path) and not os.path.isfile(full_path):
                    shutil.move(backup_path, full_path)
                    print(f"            original restored")
                results.append({"path": rel_path, "status": "error",
                                 "before": before, "after": None,
                                 "reasons": reasons, "elapsed": None, "error_msg": msg})

    total_elapsed = time.monotonic() - run_start
    conv    = sum(1 for r in results if r["status"] == "converted")
    skipped = sum(1 for r in results if r["status"] == "skipped")
    errors  = sum(1 for r in results if r["status"] == "error")

    print()
    if limit_reached:
        print(f"Limit reached ({limit}). Re-run to continue processing remaining files.")
    print(f"Done: {conv} converted, {skipped} skipped, {errors} errors  ({_fmt_elapsed(total_elapsed)})")

    run_info["total_elapsed"] = _fmt_elapsed(total_elapsed)

    html = _normalise_html(directory, results, target_str, orig_dir, args.dry_run, run_info)
    with open(report_path, "w", encoding="utf-8") as fh:
        fh.write(html)
    print(f"Report: {report_path}")

    if errors:
        sys.exit(1)


