  .summary{{display:flex;gap:20px;padding:16px 28px;background:#fff;
            border-bottom:1px solid #d2d2d7;flex-wrap:wrap}}
  .stat{{display:flex;flex-direction:column;min-width:80px}}
  .stat .val{{font-size:22px;font-weight:600}}
  .stat .lbl{{font-size:11px;color:#6e6e73;margin-top:2px}}
