def cmd_catalog(args):
    _require("ffprobe")
    directory = args.directory
    if not os.path.isdir(directory):
        sys.exit(f"Error: not a directory: {directory}")

    output = args.output or "catalog.html"

    print(f"Scanning {os.path.abspath(directory)} ...")
    entries = []
    for root, dirs, files in os.walk(directory):
        dirs.sort()
        for fname in sorted(files):
            if os.path.splitext(fname)[1].lower() in VIDEO_EXTENSIONS:
                full_path = os.path.join(root, fname)
                rel_path = os.path.relpath(full_path, directory)
                print(f"  {rel_path}")
                entries.append(_catalog_probe(full_path, rel_path))

    if not entries:
        sys.exit("No video files found.")

    html = _catalog_html(directory, entries)
    with open(output, "w", encoding="utf-8") as fh:
        fh.write(html)

    errors = sum(1 for e in entries if e["error"])
    print(f"\nReport: {output}  ({len(entries)} files"
          + (f", {errors} probe errors" if errors else "") + ")")


# ---------------------------------------------------------------------------
# Normalise
# ---------------------------------------------------------------------------

# ffprobe codec names differ from the ffmpeg encoder names
_VCODEC_PROBE = {"libx264": "h264", "libx265": "hevc", "libvpx-vp9": "vp9"}
_ACODEC_PROBE = {"libmp3lame": "mp3", "libopus": "opus"}


def _is_interlaced(stream):
    field_order = stream.get("field_order", "progressive")
    return field_order not in ("progressive", "unknown", "")


def _scale_filter(target_w, target_h):
    """Return an ffmpeg vf scale+pad expression that fits within target_w×target_h
    using lanczos resampling (good for both up- and down-scaling), then pads to
    the exact target dimensions with black bars to maintain aspect ratio."""
    return (
        f"scale={target_w}:{target_h}"
        ":force_original_aspect_ratio=decrease"
        ":flags=lanczos"
        f",pad={target_w}:{target_h}:(ow-iw)/2:(oh-ih)/2:color=black"
    )


def _tool_version(tool):
    """Return the version string for *tool* (e.g. 'ffmpeg 6.1.1'), or 'unknown'."""
    try:
        out = subprocess.check_output(
            [tool, "-version"], stderr=subprocess.STDOUT
        ).decode(errors="replace")
        first = out.splitlines()[0]          # e.g. "ffmpeg version 6.1.1 Copyright ..."
        # grab everything up to the first "Copyright" / "built" clause
        return first.split("Copyright")[0].split(" built")[0].strip()
    except Exception:
        return f"{tool} (unknown version)"


def _fmt_elapsed(secs):
    """Format elapsed seconds as 'Xm Ys' or 'Xs'."""
    secs = int(secs)
    m, s = divmod(secs, 60)
    return f"{m}m {s:02d}s" if m else f"{s}s"


def _norm_probe(path):
    """Probe *path* and return a compact summary dict for the normalise report."""
    e = {
        "size": 0, "format": "", "duration": 0.0, "bitrate": 0,
        "video_codec": "", "width": 0, "height": 0, "fps": "",
        "audio_codec": "", "channels": "", "interlaced": False,
    }
    try:
        e["size"] = os.path.getsize(path)
        data = _probe(path)
        fmt = data.get("format", {})
        e["format"]   = fmt.get("format_name", "").split(",")[0]
        e["duration"] = float(fmt.get("duration") or 0)
        e["bitrate"]  = int(fmt.get("bit_rate")   or 0)
        for s in data.get("streams", []):
            ctype = s.get("codec_type")
            if ctype == "video" and not e["video_codec"]:
                e["video_codec"] = s.get("codec_name", "")
                e["width"]       = int(s.get("width",  0))
                e["height"]      = int(s.get("height", 0))
                e["fps"]         = _fmt_fps(s.get("avg_frame_rate", ""))
                e["interlaced"]  = _is_interlaced(s)
            elif ctype == "audio" and not e["audio_codec"]:
                e["audio_codec"] = s.get("codec_name", "")
                e["channels"]    = s.get("channels", "")
    except Exception:
        pass
    return e


def _run_info_section(run_info):
    """Render the collapsible Run Information section, or empty string if no info."""
    if not run_info:
        return ""

    def row(k, v):
        return f'<tr><td>{k}</td><td>{v}</td></tr>'

    cfg_rows = "".join([
        row("Target format",   run_info.get("target_fmt", "—")),
        row("Video codec",     run_info.get("vcodec", "—")),
        row("Audio codec",     run_info.get("acodec", "—")),
        row("CRF",             run_info.get("crf", "—")),
        row("Preset",          run_info.get("preset", "—")),
        row("Audio bitrate",   run_info.get("abitrate", "—")),
        row("Target resolution", run_info.get("target_res", "—")),
        row("Deinterlace",     run_info.get("deinterlace", "—")),
        row("Originals dir",   run_info.get("orig_dir", "—")),
        row("",                ""),
        row("ffmpeg",          run_info.get("ffmpeg_ver", "—")),
        row("ffprobe",         run_info.get("ffprobe_ver", "—")),
        row("Python",          run_info.get("python_ver", "—")),
        row("",                ""),
        row("Total run time",  run_info.get("total_elapsed", "—")),
        row("Config files",    "<br>".join(run_info.get("config_files", []) or ["(none)"])),
    ])

    return f"""
<details>
  <summary>Run information</summary>
  <br>
  <table class="cfg-table">
    <tbody>{cfg_rows}</tbody>
  </table>
</details>"""


def _normalise_html(directory, results, target, orig_dir, dry_run, run_info=None):
    """Render the normalise run results as a self-contained HTML report."""
    now    = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
    absd   = os.path.abspath(directory)

    conv   = [r for r in results if r["status"] == "converted"]
    skipped= [r for r in results if r["status"] == "skipped"]
    errors = [r for r in results if r["status"] == "error"]

    size_before = sum(r["before"]["size"] for r in conv)
    size_after  = sum(r["after"]["size"]  for r in conv if r["after"])
    saved       = size_before - size_after
    saved_pct   = (saved / size_before * 100) if size_before else 0
    saved_sign  = "+" if saved < 0 else ""   # negative saved = grew

    def _cell(e):
        if not e:
            return "—"
        res = f'{e["width"]}×{e["height"]}' if e["width"] else "—"
        fps = e["fps"] or "—"
        vc  = e["video_codec"] or "—"
        ac  = e["audio_codec"] or "—"
        ch  = f' {e["channels"]}ch' if e["channels"] else ""
        br  = f'{e["bitrate"]//1000} kb/s' if e["bitrate"] else "—"
        dur = _fmt_duration(e["duration"]) if e["duration"] else "—"
        il  = ' <span class="tag">interlaced</span>' if e.get("interlaced") else ""
        return (
            f'<span class="vc">{vc}</span>{il} · {res} · {fps} fps<br>'
            f'<span class="sub">{ac}{ch} · {br} · {dur} · {_fmt_size(e["size"])}</span>'
        )

    def _delta(r):
        if not r["after"]:
            return "—"
        d = r["after"]["size"] - r["before"]["size"]
        pct = (d / r["before"]["size"] * 100) if r["before"]["size"] else 0
        cls = "pos" if d < 0 else "neg"
        sign = "" if d < 0 else "+"
        return f'<span class="{cls}">{sign}{_fmt_size(d)}<br>{sign}{pct:.1f}%</span>'

    def _elapsed_cell(r):
        e = r.get("elapsed")
        if e is None:
            return "—"
        spd = ""
        if r["before"]["duration"] and e > 0:
            ratio = r["before"]["duration"] / e
            spd = f'<br><span class="sub">{ratio:.1f}× realtime</span>'
        return f"{_fmt_elapsed(e)}{spd}"

    conv_rows = "\n".join(
        f'<tr>'
        f'<td class="path">{r["path"]}</td>'
        f'<td class="detail">{_cell(r["before"])}</td>'
        f'<td class="detail">{_cell(r["after"])}</td>'
        f'<td class="r delta">{_delta(r)}</td>'
        f'<td class="r elapsed">{_elapsed_cell(r)}</td>'
        f'<td class="reasons">{", ".join(r["reasons"])}</td>'
        f'</tr>'
        for r in conv
    )
    skip_rows = "\n".join(
        f'<tr><td class="path">{r["path"]}</td><td class="detail">{_cell(r["before"])}</td></tr>'
        for r in skipped
    )
    err_rows = "\n".join(
        f'<tr><td class="path">{r["path"]}</td>'
        f'<td class="err">{r.get("error_msg","")}</td></tr>'
        for r in errors
    )

    dry_banner = '<div class="dry-banner">Dry run — no files were changed</div>' if dry_run else ""

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Normalise Report — {absd}</title>
<style>
  *{{box-sizing:border-box;margin:0;padding:0}}
  body{{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
        font-size:13px;background:#f5f5f7;color:#1d1d1f}}
  header{{background:#1d1d1f;color:#f5f5f7;padding:20px 28px}}
