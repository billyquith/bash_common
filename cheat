#!/usr/bin/env bash
# cheat - view or edit local cheat sheets in a browser
#
# Opens a local cheat sheet collection (cloned into $BC_INSTALL_DIR/.cheat)
# in Safari (macOS) or the system browser (Cygwin). Sheets are Markdown files
# rendered via a local HTML index.
#
# Usage: cheat [-l] [-e] [-h] [SHEET]
#   SHEET   open a named cheat sheet
#   -l      list available cheat sheets
#   -e      edit the cheat sheet collection in $EDITOR
#   -h      show this help

CHLOC="$BC_INSTALL_DIR/.cheat"

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

# -e : edit
if [ "$1" = "-e" ]; then
  if [ ! -d "$CHLOC" ]; then
    git clone http:// $CHLOC
  fi
  $EDITOR $CHLOC
  exit 0
fi

SHEET=
if [ ! -z $1 ]; then
  
  if [ "$1" = "-l" ]; then
    pushd $CHLOC/sheets
    ls *.md
    popd
    exit 0
  fi
  
  if [ ! -e "$CHLOC/sheets/$1.md" ]; then
    echo "Unknown cheatsheet: $1"
    exit 1
  fi
  
  SHEET="?sheet=$1";
fi

URL="file://$CHLOC/index.html${SHEET}"

case `uname -s` in
Darwin)
  exec osascript <<EOM
    on run argv
    tell application "Safari" to open location "${URL}"
    end run
EOM
;;
CYG*) open $URL ;;
esac
