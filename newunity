#!/usr/bin/env bash
# newunity - scaffold a new Unity project directory structure
#
# Run inside the root of a new Unity project. Initialises git (if not already
# done), adds a Unity-specific .gitignore, and creates the standard Assets
# subdirectory layout (Audio, Models, Prefabs, Scenes, Scripts, etc.).
#
# Usage: newunity [-h]
#   -h   show this help

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

createGitIgnore () {
    cat <<EOM > .gitignore    
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/Assets/AssetStoreTools*

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Unity3D generated meta files
*.pidb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.unitypackage    
EOM

git add .gitignore
}

ensureDir () {
    echo Ensure dir "$1"
    [ -d $1 ] || mkdir -p $1
}

echo Git support
[ -d .git ] || git init
[ -f .gitignore ] || createGitIgnore

ensureDir Assets/Audio
ensureDir Assets/Models
ensureDir Assets/Models/Materials
ensureDir Assets/Models/Textures
ensureDir Assets/Prefabs
ensureDir Assets/Scenes
ensureDir Assets/Scripts

