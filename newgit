#!/usr/bin/env bash
# newgit - initialise a new git repository with sensible defaults
#
# Run in an existing directory to set up git with a standard .gitattributes
# (LF line endings) and a .gitignore covering common build artefacts and
# Python bytecode. Skips any file that already exists.
#
# Usage: newgit [-h]
#   -h   show this help

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

ADDED=

if [ ! -d '.git' ]; then
    git init
fi

if [ ! -f '.gitattributes' ]; then
    cat << NEWGIT_EOM > .gitattributes
* text=auto

NEWGIT_EOM
    git add .gitattributes
    ADDED=1
fi

if [ ! -f '.gitignore' ]; then
cat << NEWGIT_EOM > .gitignore

build*/

*.py[cod]
__pycache__/

NEWGIT_EOM
    git add .gitignore
    ADDED=1
fi

if [ ! -z $ADDED ]; then
    git commit -m 'Add git config'
    git log
fi
