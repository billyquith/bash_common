#!/usr/bin/env bash
# uncrust - reformat C/C++ source files using Uncrustify
#
# Applies the Allman-style uncrustify config (source_code/allman.uncrust.cfg)
# to a single file or recursively to all .h/.hpp/.inl/.cpp files in a
# directory tree.
#
# Usage: uncrust PATH [-h]
#   PATH   a source file or a directory to reformat recursively
#   -h     show this help
#
# Requires: uncrustify (install via brew or apt-get)

usage() {
    echo "Usage: $(basename $0) PATH"
    echo "  PATH   source file or directory to reformat"
    echo "  -h     show this help"
}

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

if [ ! -n "$1" ]; then
    usage; exit 1
fi

SCRIPTPATH=$(cd $(dirname $0) ; pwd -P)
WHAT=$1
UNCRUST=uncrustify
CFG=$SCRIPTPATH/source_code/allman.uncrust.cfg
TMPFILES=$(mktemp)

function reformat #(filename)
{
    echo "Indenting file $1"
    $UNCRUST -f "$1" -l cpp -c $CFG -o indentoutput.tmp
    mv indentoutput.tmp "$1"
}

function reformatlist #(filelist)
{
    echo "Indenting file $1"
    $UNCRUST -F "$1" -l cpp -c $CFG --replace --no-backup
}

function fmttree #(dir,file_ext)
{
    find $1 -name "*.$2" -type f > $TMPFILES
    reformatlist $TMPFILES
}

if [ -d "$WHAT" ]; then
    fmttree $WHAT h
    fmttree $WHAT hpp
    fmttree $WHAT inl
    fmttree $WHAT cpp
else
    if [ -f "$WHAT" ]; then
        reformat "$WHAT"
    else
        echo "ERROR: As parameter given directory or file does not exist!"
        echo "Syntax is: call_Uncrustify.sh dirname filesuffix"
        echo "Syntax is: call_Uncrustify.sh filename"
        echo "Example: call_Uncrustify.sh temp cpp"
        exit 1
    fi
fi
